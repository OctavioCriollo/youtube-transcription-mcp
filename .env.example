# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Refresh yt-dlp to the latest (incl. nightly) release on container start.
# Set to 0 for strictly reproducible / air-gapped deployments.
YTDLP_AUTO_UPDATE=1

# Datacenter-IP hardening for the Groq tier (item 2).
# Comma-separated yt-dlp player clients to rotate through.
YT_PLAYER_CLIENTS=tv,web_safari,mweb
# Base URL of the bgutil-ytdlp-pot-provider sidecar (leave unset to disable).
#YT_POT_PROVIDER_URL=http://bgutil-pot:4416

# Same-tier retry budget per error class (item 3). Blocked/fatal never retry.
MCP_RETRY_TRANSIENT=2
MCP_RETRY_RATE_LIMITED=2

# Circuit breaker (item 4): after N consecutive blocked failures on a
# provider, skip it for the cooldown window. State visible at /health.
MCP_BREAKER_THRESHOLD=3
MCP_BREAKER_COOLDOWN_S=300
#MCP_BREAKER_ENABLED=1

# How long the synchronous transcribe_* tools wait before handing the
# still-running job off to watch_transcription. Keep it BELOW your MCP
# client's tool-call timeout (gateways commonly use 60s).
MCP_SYNC_TOOL_BUDGET_S=50

# Ceiling for a single ElevenLabs HTTP call (seconds). With a YouTube source_url,
# ElevenLabs fetches the video on ITS side; if that stalls the call hangs. Bounded
# so a stall retries in minutes, not the old 1-hour default. Raise for very long
# videos if you see legitimate timeouts.
ELEVENLABS_TIMEOUT_S=900

# --- Remote YouTube login via authgate (item 8) --------------------------
# Cookies minted by the authgate service after a human logs in. The MCP uses
# them automatically while fresh and touches their mtime on each successful
# download (sliding 24h idle TTL). Must match AUTHGATE_MANAGED_COOKIES_FILE on
# the authgate service (same shared volume path).
MANAGED_YT_COOKIES_FILE=/mcp-workspace/transcription-mcp/secrets/youtube-cookies.txt
AUTHGATE_COOKIE_IDLE_TTL_S=86400
# Internal URL of the authgate service. Unset => the login tools report that
# remote login is not configured (transcription still uses the cloud fallback).
#AUTHGATE_BASE_URL=http://yt-auth:8080
# Public base the user opens; the MCP prepends it to authgate's relative path.
#AUTHGATE_PUBLIC_LOGIN_BASE=https://your-host/ytauth

# Operator override: an explicit cookies file always wins over the managed one.
#YT_COOKIES_FILE=/path/to/cookies.txt
