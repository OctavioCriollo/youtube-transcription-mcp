{
  "_comment_1": "Reference only — do NOT edit openclaw.json by hand. Use the CLI:",
  "_comment_2": "  openclaw mcp set transcripcion '<json>'",
  "_comment_3": "See docs/deploy.md for the actual install command.",
  "mcp": {
    "servers": {
      "transcripcion": {
        "command": "uvx",
        "args": [
          "--from",
          "git+https://github.com/OctavioCriollo/youtube-transcription-mcp.git",
          "youtube-transcription-mcp"
        ],
        "env": {
          "GROQ_API_KEY": "gsk_...",
          "ELEVENLABS_API_KEY": "..."
        }
      }
    }
  }
}
